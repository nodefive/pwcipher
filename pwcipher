#!/bin/bash

# pwcipher - A secure password manager using SQLCipher.
#
# Features:
#   - Encrypted SQLite database using SQLCipher.
#   - Add, Edit, Delete, Search, and List entries.
#   - No hardcoded paths; uses a configuration file (~/.pwcipherconf).
#   - Initial setup with schema creation.
#   - Dependency check for sqlcipher.

# --- Configuration & Constants ---
CONFIG_FILE="$HOME/.pwcipherconf"
SCHEMA="CREATE TABLE loginfo (id INTEGER PRIMARY KEY, account TEXT, login TEXT, passwd TEXT, url TEXT, info TEXT);"

# Colors for better UI
RED=$'\e[0;31m'
GREEN=$'\e[0;32m'
YELLOW=$'\e[1;33m'
BLUE=$'\e[0;34m'
BOLD=$'\e[1m'
NC=$'\e[0m' # No Color

# --- Helper Functions ---

# Print help message
show_help() {
    cat << EOF
${BOLD}pwcipher${NC} - Secure Password Manager (SQLCipher)

${BOLD}Usage:${NC} pwcipher [OPTION] [TERM]

${BOLD}Options:${NC}
  -a            Add a new account entry.
  -e [ID]       Edit an existing entry by ID.
  -d [ID]       Delete an entry by ID.
  -f            List all entries in the database.
  -w            ${RED}WIPE all contents from the database.${NC} (Dangerous!)
  --help        Display this detailed help message.

${BOLD}Search:${NC}
  pwcipher [TERM]   Searches for [TERM] in account names or IDs.

${BOLD}Instructions:${NC}
  - For ${BOLD}INFO${NC} fields: Press ${YELLOW}Enter${NC} for new lines.
  - To ${BOLD}Save/Finish${NC} the info field, press ${YELLOW}Ctrl+D${NC} on a new line.
  - Leave fields blank during ${BOLD}Edit${NC} to keep current values.
EOF
}

# Check for sqlcipher dependency
check_dependency() {
    if ! command -v sqlcipher >/dev/null 2>&1; then
        echo -e "${RED}Error: 'sqlcipher' is not installed.${NC}"
        echo
        echo "Please install it using your package manager:"
        echo "  macOS (Homebrew):    brew install sqlcipher"
        echo "  Debian/Ubuntu/WSL:  sudo apt update && sudo apt install sqlcipher"
        echo "  Fedora:             sudo dnf install sqlcipher"
        echo "  Arch Linux:         sudo pacman -S sqlcipher"
        echo
        exit 1
    fi
}

# Initialize database on first run
init_db() {
    echo -e "${BLUE}=== pwcipher Initial Setup ===${NC}"
    echo "This will set up your encrypted database storage."
    echo
    read -r -p "Enter the full path for your database file (e.g., $HOME/passwords.db): " db_path
    
    # Expand tilde
    db_path="${db_path/#\~/$HOME}"
    
    if [ -f "$db_path" ]; then
        echo -e "${YELLOW}Database file already exists at $db_path.${NC}"
    else
        read -r -s -p "Enter a strong encryption password: " db_pass
        echo
        read -r -s -p "Confirm encryption password: " db_pass_confirm
        echo
        
        if [ "$db_pass" != "$db_pass_confirm" ]; then
            echo -e "${RED}Passwords do not match. Aborting.${NC}"
            exit 1
        fi
        
        # Create directory if needed
        mkdir -p "$(dirname "$db_path")"
        
        # Initialize with schema - using -cmd to avoid 'ok' output
        sqlcipher -cmd "PRAGMA key = '$db_pass';" "$db_path" "$SCHEMA" > /dev/null
        
        if [ $? -eq 0 ]; then
            echo -e "${GREEN}Database successfully created and encrypted.${NC}"
        else
            echo -e "${RED}Failed to create database.${NC}"
            exit 1
        fi
    fi
    
    echo "DB_PATH=\"$db_path\"" > "$CONFIG_FILE"
    chmod 600 "$CONFIG_FILE"
}

# Run a SQL query against the database
run_query() {
    local query="$1"
    # Use -batch and redirect stdout to grep -v to strictly remove any 'ok' leaks
    sqlcipher -batch -list -noheader -cmd "PRAGMA key = '$DB_PASS';" "$DB_PATH" "$query" 2>/dev/null | grep -v '^ok$'
}

# Format and display a single record
display_record() {
    local row="$1"
    # Skip rows that don't look like our data
    [[ "$row" != *"|"* ]] && return

    IFS='|' read -r id account login passwd url info <<< "$row"
    
    printf "${BLUE} ACCOUNT: ${BOLD}%-25s${NC} ID: ${YELLOW}%s${NC}\n" "${account^^}" "$id"
    echo -e "${BLUE} ------------------------------------------------${NC}"
    printf "  ${BOLD}LOGIN${NC}    : %s\n" "$login"
    printf "  ${BOLD}PASS${NC}     : %s\n" "$passwd"
    printf "  ${BOLD}URL${NC}      : %s\n" "$url"
    if [ -n "$info" ]; then
        # Format info: Replace literal \n with actual newlines and indent
        # Use a more robust way to replace \n strings
        local formatted_info
        formatted_info=$(echo "$info" | sed 's/\\n/\n             /g')
        echo -e "  ${BOLD}INFO${NC}     : $formatted_info"
    fi
    echo
}

# Helper to read multi-line input
read_multiline() {
    local prompt="$1"
    # Redirect prompt to stderr so it's not captured by $(read_multiline ...)
    echo -e "$prompt ${YELLOW}(Press Ctrl+D to finish)${NC}:" >&2
    local content
    content=$(cat)
    # Replace actual newlines with literal \n for storage
    # Using perl or a more reliable sed for multi-line replacement
    echo "$content" | sed ':a;N;$!ba;s/\n/\\n/g'
}

# --- Main Logic ---

check_dependency

if [ ! -f "$CONFIG_FILE" ]; then
    init_db
fi

# shellcheck source=/dev/null
source "$CONFIG_FILE"

if [ -z "$1" ] || [ "$1" == "--help" ]; then
    show_help
    exit 0
fi

# Prompt for password
read -r -s -p "Encryption Password: " DB_PASS
echo

# Validate password by checking if we can read the schema
if ! run_query "SELECT count(*) FROM sqlite_master WHERE type='table' AND name='loginfo';" | grep -q "1"; then
    echo -e "${RED}Error: Invalid password or database is not initialized correctly.${NC}"
    exit 1
fi

case "$1" in
    -a)
        echo -e "${GREEN}=== Add Account Entry ===${NC}"
        read -r -p "Account Name: " account
        read -r -p "Login: " login
        read -r -p "Password: " pass
        read -r -p "URL: " url
        info=$(read_multiline "Additional Info")
        
        # Escape single quotes for SQL
        account="${account//\'/\'\'}"
        login="${login//\'/\'\'}"
        pass="${pass//\'/\'\'}"
        url="${url//\'/\'\'}"
        info="${info//\'/\'\'}"

        run_query "INSERT INTO loginfo (account, login, passwd, url, info) VALUES ('$account', '$login', '$pass', '$url', '$info');"
        echo -e "${GREEN}Account added successfully.${NC}"
        ;;
    -e)
        id="$2"
        [ -z "$id" ] && read -r -p "Enter Account ID to edit: " id
        
        record=$(run_query "SELECT * FROM loginfo WHERE id = $id;")
        if [ -z "$record" ]; then
            echo -e "${RED}Record with ID $id not found.${NC}"
            exit 1
        fi
        
        display_record "$record"
        echo -e "${YELLOW}Enter new values (leave blank to keep current):${NC}"
        read -r -p "New Account Name: " n_account
        read -r -p "New Login: " n_login
        read -r -p "New Password: " n_pass
        read -r -p "New URL: " n_url
        
        echo -e "New Info ${YELLOW}(Press Ctrl+D to finish or Leave Empty to skip)${NC}:"
        n_info=$(cat)
        
        [ -n "$n_account" ] && run_query "UPDATE loginfo SET account = '${n_account//\'/\'\'}' WHERE id = $id;"
        [ -n "$n_login" ]   && run_query "UPDATE loginfo SET login = '${n_login//\'/\'\'}' WHERE id = $id;"
        [ -n "$n_pass" ]    && run_query "UPDATE loginfo SET passwd = '${n_pass//\'/\'\'}' WHERE id = $id;"
        [ -n "$n_url" ]     && run_query "UPDATE loginfo SET url = '${n_url//\'/\'\'}' WHERE id = $id;"
        
        if [ -n "$n_info" ]; then
            n_info_esc=$(echo "$n_info" | sed ':a;N;$!ba;s/\n/\\n/g')
            run_query "UPDATE loginfo SET info = '${n_info_esc//\'/\'\'}' WHERE id = $id;"
        fi
        
        echo -e "${GREEN}Record updated successfully.${NC}"
        # Display the updated record
        updated_record=$(run_query "SELECT * FROM loginfo WHERE id = $id;")
        display_record "$updated_record"
        ;;
    -d)
        id="$2"
        [ -z "$id" ] && read -r -p "Enter Account ID to delete: " id
        
        record=$(run_query "SELECT * FROM loginfo WHERE id = $id;")
        if [ -z "$record" ]; then
            echo -e "${RED}Record with ID $id not found.${NC}"
            exit 1
        fi
        
        display_record "$record"
        read -r -p "Are you sure you want to delete this entry? (yes/no): " confirm
        if [ "$confirm" == "yes" ]; then
            run_query "DELETE FROM loginfo WHERE id = $id;"
            echo -e "${GREEN}Record deleted.${NC}"
        else
            echo "Deletion cancelled."
        fi
        ;;
    -f)
        echo -e "${BLUE}=== Full Account List ===${NC}"
        results=$(run_query "SELECT * FROM loginfo ORDER BY account ASC;")
        if [ -z "$results" ]; then
            echo "Database is empty."
        else
            while IFS= read -r line; do
                display_record "$line"
            done <<< "$results"
        fi
        ;;
    -w)
        echo -e "${RED}${BOLD}!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!${NC}"
        echo -e "${RED}${BOLD}WARNING: YOU ARE ABOUT TO WIPE ALL DATABASE CONTENT!${NC}"
        echo -e "${RED}${BOLD}!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!${NC}"
        read -r -p "Type 'WIPE' to confirm: " confirm
        if [ "$confirm" == "WIPE" ]; then
            run_query "DELETE FROM loginfo;"
            echo -e "${GREEN}All records have been wiped.${NC}"
        else
            echo "Wipe operation cancelled."
        fi
        ;;
    -*)
        echo -e "${RED}Unknown option: $1${NC}"
        show_help
        exit 1
        ;;
    *)
        # Search functionality
        term="$1"
        # Escape single quotes for search term
        term_esc="${term//\'/\'\'}"
        results=$(run_query "SELECT * FROM loginfo WHERE account LIKE '%$term_esc%' OR id = '$term_esc';")
        if [ -z "$results" ]; then
            echo -e "${YELLOW}No matches found for '$term'.${NC}"
        else
            while IFS= read -r line; do
                display_record "$line"
            done <<< "$results"
        fi
        ;;
esac
